{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "jsx": "preserve"
  },
  "include": [
    "src/app/api/**/*.ts",
    "src/lib/api/**/*.ts",
    "src/lib/auth.ts",
    "src/lib/supabase/admin.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
